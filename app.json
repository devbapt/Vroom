{
  "expo": {
    "name": "vroom",
    "slug": "vroom",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_vroom_Couleur.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#140102"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#140102"
      },
      "edgeToEdgeEnabled": true
    },
    "scheme": "vroom",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Vroom utilise ta position pour t'afficher les événements et les routes à proximité.",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ]
    ]
  }
}
